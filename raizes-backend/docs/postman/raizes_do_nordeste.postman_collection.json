  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login cliente",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"cliente@exemplo.com\",\n  \"password\": \"Cliente@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function(){pm.response.to.have.status(200);});",
                  "var json = pm.response.json(); pm.collectionVariables.set('token', json.access);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login gerente",
